datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  role         String         @default("guest") // "guest" | "staff"
  createdAt    DateTime       @default(now())
  bookings     Booking[]
  housekeeping Housekeeping[] @relation("StaffHousekeeping")
}

model Room {
  id           String         @id @default(uuid())
  name         String
  price        Float
  description  String
  rating       Float          @default(5.0)
  image        String // Asset path or url
  amenities    String // Comma-separated or JSON list stored as string
  isAvailable  Boolean        @default(true)
  bookings     Booking[]
  housekeeping Housekeeping[]
}

model Booking {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  checkIn     String // Date string (YYYY-MM-DD)
  checkOut    String // Date string (YYYY-MM-DD)
  guestsCount Int      @default(2)
  roomsCount  Int      @default(1)
  status      String   @default("pending") // "pending" | "confirmed" | "checked-in" | "checked-out" | "cancelled"
  totalCost   Float
  createdAt   DateTime @default(now())
}

model Housekeeping {
  id              String   @id @default(uuid())
  roomId          String
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignedStaffId String?
  assignedStaff   User?    @relation("StaffHousekeeping", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  status          String   @default("pending") // "pending" | "in-progress" | "cleaned"
  notes           String?
  updatedAt       DateTime @updatedAt
}

model Testimonial {
  id     String @id @default(uuid())
  name   String
  role   String
  text   String
  rating Int    @default(5)
}

model Service {
  id          String @id @default(uuid())
  iconName    String // name of the lucide icon
  title       String
  description String
}

model Gallery {
  id   String @id @default(uuid())
  src  String
  alt  String
  span String @default("") // e.g. "row-span-2", "col-span-2"
}
